{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/subscriptions/plans": {
      "get": {
        "operationId": "SubscriptionsController_getPlans",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Список доступных тарифных планов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PlanViewDto" }
                }
              }
            }
          }
        },
        "summary": "Получить список тарифных планов подписки",
        "tags": ["Subscriptions", "Subscriptions"]
      }
    },
    "/api/v1/subscriptions/my-payments": {
      "get": {
        "description": "Возвращает только успешные платежи (status = PAID) текущего авторизованного пользователя.",
        "operationId": "SubscriptionsController_getMyPayments",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Пагинированный список платежей пользователя со статусом PAID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedPaymentsSwaggerDto"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован или передан недействительный access-токен"
          }
        },
        "security": [{ "access-token": [] }],
        "summary": "Получить историю своих платежей по подписке",
        "tags": ["Subscriptions"]
      }
    },
    "/api/v1/subscriptions/stripe/checkout-session": {
      "post": {
        "operationId": "SubscriptionsController_createCheckoutSession",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCheckoutSessionInputDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Успешно создана Stripe Checkout Session. В ответе возвращается URL для редиректа.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutSessionUrlViewDto"
                }
              }
            }
          },
          "400": {
            "description": "Передан несуществующий или недоступный тарифный план"
          },
          "401": {
            "description": "Пользователь не авторизован или передан недействительный access-токен"
          }
        },
        "security": [{ "access-token": [] }],
        "summary": "Создать Stripe Checkout Session для оформления подписки",
        "tags": ["Subscriptions"]
      }
    },
    "/api/v1/subscriptions/stripe/auto-renewal": {
      "put": {
        "operationId": "SubscriptionsController_updateAutoRenewal",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAutoRenewalInputDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Автопродление успешно добавлено/убрано. Если значение параметра autoRenewal, переданное в запросе, совпадает с текущим значением, сохранённым в системе, ответом также будет статус 204 No Content"
          },
          "400": {
            "description": "У пользователя отсутствует активные подписки"
          },
          "401": {
            "description": "Пользователь не авторизован или передан недействительный access-токен"
          }
        },
        "security": [{ "access-token": [] }],
        "summary": "Поставить или убрать автопродление подписки",
        "tags": ["Subscriptions"]
      }
    }
  },
  "info": {
    "title": "SnapFlow Payments API",
    "description": "Публичное HTTP API сервиса оплат: тарифы и создание Stripe Checkout Session. Вебхуки Stripe и служебные маршруты в документацию не входят.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    { "name": "Subscriptions", "description": "Тарифы и оформление подписки" }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Access token пользователя (тот же JWT, что для core API). Заголовок Authorization: Bearer …"
      }
    },
    "schemas": {
      "PlanViewDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Уникальный идентификатор тарифного плана",
            "example": "plan_monthly_basic"
          },
          "label": {
            "type": "string",
            "description": "Человекочитаемое название плана",
            "example": "Месячная подписка (базовый тариф)"
          },
          "priceInCents": {
            "type": "number",
            "description": "Стоимость плана в центах (minor units)",
            "example": 990
          }
        },
        "required": ["id", "label", "priceInCents"]
      },
      "PaymentViewDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "Идентификатор пользователя",
            "example": "1"
          },
          "subscriptionId": {
            "type": "string",
            "description": "Идентификатор подписки",
            "example": "42"
          },
          "dateOfPayment": {
            "type": "string",
            "description": "Дата и время успешного платежа (ISO-8601)",
            "example": "2026-04-21T10:30:00.000Z"
          },
          "endDateOfSubscription": {
            "type": "object",
            "description": "Дата окончания подписки (ISO-8601) или null",
            "example": "2026-05-21T10:30:00.000Z",
            "nullable": true
          },
          "price": {
            "type": "number",
            "description": "Сумма платежа в minor units",
            "example": 1000
          },
          "subscriptionType": {
            "type": "string",
            "description": "Человекочитаемый тип подписки",
            "example": "Business Monthly",
            "enum": ["Business Monthly", "Business Yearly"]
          },
          "provider": {
            "type": "string",
            "description": "Платежный провайдер",
            "example": "STRIPE",
            "enum": ["STRIPE", "PAYPAL"]
          }
        },
        "required": [
          "userId",
          "subscriptionId",
          "dateOfPayment",
          "endDateOfSubscription",
          "price",
          "subscriptionType",
          "provider"
        ]
      },
      "PaginatedPaymentsSwaggerDto": {
        "type": "object",
        "properties": {
          "pagesCount": {
            "type": "number",
            "description": "Количество страниц",
            "example": 1
          },
          "page": {
            "type": "number",
            "description": "Текущая страница",
            "example": 1
          },
          "pageSize": {
            "type": "number",
            "description": "Размер страницы",
            "example": 10
          },
          "totalCount": {
            "type": "number",
            "description": "Общее количество элементов",
            "example": 1
          },
          "items": {
            "description": "Список платежей. Возвращаются только платежи со статусом PAID",
            "type": "array",
            "items": { "$ref": "#/components/schemas/PaymentViewDto" }
          }
        },
        "required": ["pagesCount", "page", "pageSize", "totalCount", "items"]
      },
      "CreateCheckoutSessionInputDto": {
        "type": "object",
        "properties": {
          "planId": {
            "type": "string",
            "description": "Идентификатор тарифного плана подписки",
            "example": "plan_monthly_basic"
          }
        },
        "required": ["planId"]
      },
      "CheckoutSessionUrlViewDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL Stripe Checkout Session, на который нужно перенаправить пользователя",
            "example": "https://checkout.stripe.com/c/pay_1234567890abcdef"
          }
        },
        "required": ["url"]
      },
      "UpdateAutoRenewalInputDto": {
        "type": "object",
        "properties": {
          "autoRenewal": {
            "type": "boolean",
            "description": "Флаг автоматического продления подписки",
            "example": "false"
          }
        },
        "required": ["autoRenewal"]
      }
    }
  }
}
