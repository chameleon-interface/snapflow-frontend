!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated API docs
/docs/

# misc
mock-server
.idea
.vscode
*.code-workspace
.DS_Store
