{
  "name": "snapflow-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "prepare": "husky",
    "api:generate": "orval --config orval.config.ts",
    "dev": "next dev",
    "build": "next build",
    "build:production": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format:write": "prettier \"**/*.{js,ts,jsx,tsx,css,scss,json,md,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,ts,jsx,tsx,css,scss,json,md,yml,yaml}\" --check",
    "stylelint": "stylelint \"**/*.{css,scss,module.css,module.scss}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,module.css,module.scss}\" --fix",
    "i18n:validate": "node scripts/run-i18n-validate.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm format:write --",
      "pnpm lint --"
    ],
    "*.{css,scss,module.css,module.scss}": [
      "pnpm format:write --",
      "pnpm stylelint --"
    ],
    "*.{json,md,yml,yaml}": [
      "pnpm format:write --"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.90.19",
    "axios": "1.13.5",
    "cc-gram": "1.2.10",
    "clsx": "2.1.1",
    "disposable-email-domains": "1.0.62",
    "next": "16.1.6",
    "next-intl": "4.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "5.5.6",
    "react-google-recaptcha": "3.1.0",
    "react-hook-form": "7.71.1",
    "react-hot-toast": "2.6.0",
    "snapflow-ui-kit": "1.2.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "5.91.3",
    "@tanstack/react-query-devtools": "5.91.3",
    "@types/node": "25.0.10",
    "@types/react": "19.2.9",
    "@types/react-dom": "19",
    "@types/react-google-recaptcha": "2.1.9",
    "eslint": "9",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.3.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "orval": "8.5.3",
    "prettier": "3.8.1",
    "stylelint": "17.0.0",
    "stylelint-config-clean-order": "8.0.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5"
  }
}
