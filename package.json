{
  "name": "snapflow-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "build:production": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format:write": "prettier \"**/*.{js,ts,jsx,tsx,css,scss,json,md,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,ts,jsx,tsx,css,scss,json,md,yml,yaml}\" --check",
    "stylelint": "stylelint \"**/*.{css,scss,module.css,module.scss}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,module.css,module.scss}\" --fix"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm format:write --",
      "pnpm lint --"
    ],
    "*.{css,scss,module.css,module.scss}": [
      "pnpm format:write --",
      "pnpm stylelint --"
    ],
    "*.{json,md,yml,yaml}": [
      "pnpm format:write --"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.19",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.71.1"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "5.91.3",
    "@types/node": "20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "eslint": "9",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.0",
    "stylelint": "17.0.0",
    "stylelint-config-css-modules": "4.5.1",
    "stylelint-config-prettier": "9.0.5",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5"
  }
}
